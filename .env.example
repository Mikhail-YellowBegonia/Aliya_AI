# Aliya AI Configuration Template
# 请将此文件复制为 .env 并填写你的私密信息

# --- LLM API 密钥与端点 ---
# 支持 OpenAI, Anthropic, Gemini, DeepSeek, OneAPI 等
LITELLM_MODEL="openai/gpt-4o"
LLM_API_KEY="sk-..."
LLM_BASE_URL="https://api.openai.com/v1"

# --- MCP (Model Context Protocol) 服务 ---
# 本地或远程 MCP 服务器地址
MCP_WEATHER_SERVER_URL="http://localhost:8000"
MCP_SEARCH_SERVER_URL="http://localhost:8001"

# --- 用户信息与个性化 ---
# 虽然不支持多用户，但可以定义当前主人的称呼
USER_NAME="Master"
ALIYA_NAME="Aliya"

# --- 运行配置 ---
DB_PATH="aliya.db"
LOG_LEVEL="INFO"
MAX_SUB_ITERATIONS=3
METAFETCH_INTERVAL=60
