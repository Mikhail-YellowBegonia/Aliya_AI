@startuml seq_v2_safe

box "remote"
participant "LLM API" as api
participant "MCP Server" as mcp
end box

box "local"
boundary "Terminal" as cli
end box

box "main"
box "I/O Loop"
control "Main FSM" as main
end box

box "Agent Loop"
participant "Context Assembly" as asm
control "Aliya FSM" as aliya
participant "Interceptor" as intrcpt
' 内存中的临时对象，阅后即焚
entity "Scratchpad" as scratch
database "cache"
end box

box "Database"
participant "Meta (0)" as meta
collections "History (+N)" as r.db
collections "Prompt (-N)" as rw.db
database "subsession"
end box

== Scene 1: Lock & Meta Update ==

cli -> main : user message
main -> main : SET_STATE(BUSY)
' 在处理任何逻辑前，先刷新瞬时感官
main -> meta : Update (Time, Weather, System)
main -> cli : LOCK_INPUT

== Scene 2: The 3-Iteration Cognitive Turn [Bound by turn_id] ==

group COGNITIVE TURN [Atomic Bundle]
    note over main : Generate current_turn_id
    
    group MAIN TOOL
        note over asm : Order: -N > +N > Cache > 0
        asm -> aliya : context
        aliya <-> api : request tool intent
        aliya -> cache : save [stage:TOOL_CALL]
    end

    group SUB LOOP [Optional]
        aliya -> intrcpt : call MCP
        mcp -> intrcpt : raw data
        intrcpt -> scratch : cleaned natural language [S]
        intrcpt -> cache : save [stage:SUB_RETURN]
    end

    group MAIN HIDDEN
        note over asm : Order: -N > +N > Cache > 0 > [S]
        asm -> aliya : context
        aliya <-> api : request thought
        aliya -> cache : save [stage:THOUGHT]
    end

    group MAIN FORMAL
        note over asm : Order: -N > +N > Cache > 0 > [Cache*]
        note right of asm : [Cache*] now includes:\nUser Msg + Tool Call + Sub Return + Thought
        asm -> aliya : context
        aliya <-> api : generate response
        aliya -> cache : save [stage:FINAL_REPLY]
        aliya -> cli : SHOW_REPLY
    end
end

group SLICE & PURGE (Post-Process)
    main -> scratch : PURGE
    aliya -> aliya : Analyze Slice
    main -> main : SET_STATE(IDLE)
end

@enduml