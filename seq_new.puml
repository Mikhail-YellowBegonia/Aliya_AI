@startuml seq_v2_safe

box "remote"
participant "LLM API" as api
participant "MCP Server" as mcp
end box

box "local"
boundary "Terminal" as cli
end box

box "main"
box "I/O Loop"
control "Main FSM" as main
end box

box "Agent Loop"
participant "Context Assembly" as asm
control "Aliya FSM" as aliya
participant "Interceptor" as intrcpt
' 内存中的临时对象，阅后即焚
entity "Scratchpad" as scratch
database "cache"
end box

box "Database"
participant "Meta (0)" as meta
collections "History (+N)" as r.db
collections "Prompt (-N)" as rw.db
database "subsession"
end box

== Scene 1: Lock & Meta Update ==

cli -> main : user message
main -> main : SET_STATE(BUSY)
' 在处理任何逻辑前，先刷新瞬时感官
main -> meta : Update (Time, Weather, System)
main -> cli : LOCK_INPUT

== Scene 2: The 3-Iteration Cycle ==

group MAIN TOOL
    note over asm : Order: -N > +N > Cache > 0
    rw.db -> asm
    r.db -> asm
    cache -> asm
    meta -> asm
    asm -> aliya : context
    aliya <-> api : request tool intent
    aliya -> intrcpt : handle action
end

group SUB LOOP [迭代限制: iter < 3]
    note over aliya : 重置 SUB_ITER_COUNT = 0
    
    loop 直到 识别到 [SUB QUIT] 或 iter >= 3
        note over aliya : SUB_ITER_COUNT ++
        
        ' 步骤 1: 组装子循环专属上下文
        note over asm : Order: -N > subsession > Scratchpad > 0
        rw.db -> asm : 加载核心指令
        subsession -> asm : 加载子 Agent 私有上下文
        scratch -> asm : 加载上一轮工具原始返回
        meta -> asm : 加载当前 0 号位状态
        asm -> aliya : 交付 [SUB 组装上下文]

        ' 步骤 2: 获取执行 Key 并进行 API 推理
        aliya --> main : 申请 int.key (subsession 写入权)
        main --> keys : 分配 subsession 写入权
        
        alt API 调用成功
            aliya <-> api : 请求 [动作决策/参数生成]
        else API 失败
            aliya -> aliya : 执行 "Error as Answer"\n构造虚拟错误反馈
        end

        ' 步骤 3: 拦截动作并调用 MCP
        aliya -> intrcpt : 输出包含 [Action: ...]
        
        alt 正常调用
            intrcpt <-> mcp : 访问远程/本地 MCP Server
            mcp -> intrcpt : 返回 Raw Data / JSON
        else 工具超时或崩溃
            intrcpt -> intrcpt : 捕获 Exception
            intrcpt -> intrcpt : 格式化 Sanitized Error\n(防止上下文爆炸)
        end

        ' 步骤 4: 写入 Scratchpad 与 subsession
        intrcpt -> scratch : 写入/更新 [Scratchpad]\n(供下一轮或主脑读取)
        intrcpt -> subsession : 更新 [subsession]\n(维持子 Agent 逻辑链)

        ' 步骤 5: 退出判定
        intrcpt -> aliya : 检定输出是否包含 [SUB QUIT]
        
        alt 识别到 [SUB QUIT] 或 强制熔断 (iter=3)
            aliya -> aliya : 退出 SUB LOOP
            aliya --> main : 释放 int.key (subsession)
        else 需要下一步 [SUB NEXT]
            aliya -> aliya : 继续下一轮 SUB 迭代
        end
    end
end

group MAIN HIDDEN
    note over asm : Order: -N > +N > Cache > 0 > Scratchpad
    rw.db -> asm
    r.db -> asm
    cache -> asm
    meta -> asm
    scratch -> asm : get ephemeral result
    asm -> aliya : context
    aliya <-> api : request (Hidden thought)
    aliya -> cache : append hidden reply (Thought only)
end

group MAIN FORMAL
    note over asm : Order: -N > +N > Cache > 0 > Scratchpad > Cache*
    rw.db -> asm
    r.db -> asm
' 这里的 cache 包含前面的对话，cache* 指当前轮次的最关键用户输入
    cache -> asm 
    meta -> asm
    scratch -> asm 
    asm -> aliya : context
    aliya <-> api : request (Natural Language)
    aliya -> cache : append formal reply
    aliya -> cli : UNLOCK_INPUT & SHOW_REPLY
' 任务结束，清空内存便签
    main -> scratch : PURGE (阅后即焚)
end

group SLICE (Post-Process)
    aliya -> aliya : Analyze Slice
    alt if slice needed
        cache -> r.db : commit
        aliya -> cache : clear
    end
    main -> main : SET_STATE(IDLE)
end

@enduml